{
    "editor.formatOnSave": true,
    "[html]": {
        "editor.formatOnSave": false,
    },
    "cSpell.enabled": true,
    "cSpell.words": [
        "acfun",
        "akamaized",
        "balh",
        "bangumi",
        "bili",
        "bilibili",
        "biliplus",
        "ipcjs",
        "playinfo",
        "playurl",
        "upos",
        "vuejs"
    ],
    "typescript.tsdk": "node_modules\\typescript\\lib",
    "typescript.preferences.autoImportSpecifierExcludeRegexes": [
        // src目录是文件夹下的"私有目录", 不允许被自动引入
        // - '/@/components/Table/src/types/table': ❌️, 外部不应该导入私有目录里面的方法
        // - '/@/components/Table': ✅️, Table下所有需要对外暴露的方法, 应该在/@/components/Table/index.ts中统一导出
        // - './src/types/table': ✅️, index.ts里面可以用相对导入
        // - './types/table': ✅️, src目录里面的文件, 可以用相对导入
        "\\w/src/",
    ],
}